{"ast":null,"code":"import { ref, computed, onBeforeUnmount } from 'vue';\nimport { Icon } from '@iconify/vue';\nimport avatar from '@/assets/mini1.jpg';\n\n// Props\nconst fullText = `This is my little video project, inspired by Instagram Reels. I wanted to create a simple and elegant video player that mimics the feel of Reels, with smooth controls and a clean interface. It's built using Vue.js and Tailwind CSS, and I'm really happy with how it turned out!`;\nexport default {\n  __name: 'Reel',\n  props: {\n    videoSrc: {\n      type: String,\n      required: true\n    }\n  },\n  emits: ['close'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n\n    // Emits\n\n    // State\n    const isPlaying = ref(false);\n    const isMuted = ref(true);\n    const showMore = ref(false);\n    const videoRef = ref(null);\n    const shortText = computed(() => {\n      return fullText.substring(0, 120) + '...';\n    });\n\n    // Timer\n    let hideTimer = null;\n    const controlsHidden = ref(false);\n\n    // Methods\n    const togglePlay = () => {\n      const video = videoRef.value;\n      if (!video) return;\n      if (video.paused || video.ended) {\n        video.play().then(() => {\n          isPlaying.value = true;\n          startHideTimer();\n        }).catch(err => console.warn('Play blocked', err));\n      } else {\n        video.pause();\n        isPlaying.value = false;\n        controlsHidden.value = false;\n        clearHideTimer();\n      }\n    };\n    const toggleMute = () => {\n      const video = videoRef.value;\n      if (video) {\n        video.muted = !video.muted;\n        isMuted.value = video.muted;\n      }\n    };\n    const onPlay = () => {\n      isPlaying.value = true;\n      startHideTimer();\n    };\n    const onPause = () => {\n      isPlaying.value = false;\n      controlsHidden.value = false;\n      clearHideTimer();\n    };\n    const startHideTimer = () => {\n      clearHideTimer();\n      hideTimer = setTimeout(() => {\n        controlsHidden.value = true;\n      }, 500);\n    };\n    const clearHideTimer = () => {\n      if (hideTimer) {\n        clearTimeout(hideTimer);\n        hideTimer = null;\n      }\n    };\n    const resetHideTimer = () => {\n      if (isPlaying.value) {\n        controlsHidden.value = false;\n        startHideTimer();\n      }\n    };\n    const handleVideoClick = e => {\n      e.stopPropagation();\n      togglePlay();\n    };\n    const goToMainfeed = () => {\n      console.log('→ Going to main feed');\n    };\n\n    // Cleanup\n    onBeforeUnmount(() => {\n      if (videoRef.value) {\n        videoRef.value.pause?.();\n      }\n    });\n    const __returned__ = {\n      isPlaying,\n      isMuted,\n      showMore,\n      videoRef,\n      fullText,\n      shortText,\n      get hideTimer() {\n        return hideTimer;\n      },\n      set hideTimer(v) {\n        hideTimer = v;\n      },\n      controlsHidden,\n      togglePlay,\n      toggleMute,\n      onPlay,\n      onPause,\n      startHideTimer,\n      clearHideTimer,\n      resetHideTimer,\n      handleVideoClick,\n      goToMainfeed,\n      ref,\n      computed,\n      onBeforeUnmount,\n      get Icon() {\n        return Icon;\n      },\n      get avatar() {\n        return avatar;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onBeforeUnmount","Icon","avatar","fullText","isPlaying","isMuted","showMore","videoRef","shortText","substring","hideTimer","controlsHidden","togglePlay","video","value","paused","ended","play","then","startHideTimer","catch","err","console","warn","pause","clearHideTimer","toggleMute","muted","onPlay","onPause","setTimeout","clearTimeout","resetHideTimer","handleVideoClick","e","stopPropagation","goToMainfeed","log"],"sources":["D:/login-feed/src/views/Reel.vue"],"sourcesContent":["<template>\r\n    \r\n  <div\r\n    class=\"fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm\"\r\n    @click.self=\"$emit('close')\">\r\n\r\n     <!-- Back to feed button -->\r\n      <button\r\n        @click=\"goToMainfeed\"\r\n        class=\"absolute top-6 left-6 p-3 rounded-xl bg-green-600\r\n         hover:bg-green-700 border-4 \r\n         border-green-500 hover:border-green-400 text-white \r\n         transition-all \r\n         duration-200 z-40 shadow-lg\" >\r\n        <Icon icon=\"tdesign:chat-bubble\" class=\"w-9 h-9\" />\r\n      </button>\r\n\r\n\r\n\r\n\r\n    <div\r\n      class=\"relative w-full max-w-[420px] aspect-[9/16] bg-gray-900 rounded-3xl overflow-hidden shadow-2xl ring-1 ring-white/10 \"\r\n      @click.stop>\r\n      <!-- VIDEO PLAYER -->\r\n      <div class=\"absolute inset-0\">\r\n        <video\r\n          ref=\"videoRef\"\r\n          class=\"h-full w-full object-cover\"\r\n          playsinline\r\n          loop\r\n          muted\r\n          :src=\"videoSrc\"\r\n          @click=\"togglePlay\"\r\n          @play=\"isPlaying = true\"\r\n          @pause=\"isPlaying = false\"\r\n        >\r\n    </video>\r\n\r\n        <!-- Gradient overlay -->\r\n        <div class=\"absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/70 pointer-events-none\" />\r\n      </div>\r\n\r\n      <!-- Top bar -->\r\n      <div class=\"absolute top-4 left-4 right-4 flex items-center justify-between z-30\">\r\n        <div class=\"flex-1 h-1 bg-white/40 rounded-full overflow-hidden\">\r\n          <div class=\"h-full w-3/5 bg-white rounded-full transition-all duration-[4500ms]\" />\r\n        </div>\r\n\r\n        <button\r\n          @click=\"$emit('close')\"\r\n          class=\"ml-3 p-2 rounded-full hover:bg-white/20 text-white transition-colors\"\r\n        >\r\n          <Icon icon=\"mdi:close\" class=\"w-7 h-7\" />\r\n        </button>\r\n      </div>\r\n\r\n      <!-- Bottom info -->\r\n      <div class=\"absolute bottom-0 left-0 right-0 p-5 pb-10\">\r\n        <div class=\"flex items-center justify-between mb-4\">\r\n          <div class=\"flex items-center gap-3\">\r\n            <div class=\"w-10 h-10 rounded-full ring-2 ring-white/50 overflow-hidden shadow-sm\">\r\n              <img :src=\"avatar\" alt=\"Jena\" class=\"w-full h-full object-cover\" />\r\n            </div>\r\n            <div class=\"text-white\">\r\n              <p class=\"font-semibold\">Jena</p>\r\n              <p class=\"text-xs text-white/80\">3h ago</p>\r\n            </div>\r\n          </div>\r\n\r\n          <button class=\"px-5 py-1.5 bg-white/95 text-black text-sm font-medium rounded-full hover:bg-white transition\">\r\n            Follow\r\n          </button>\r\n        </div>\r\n\r\n        <p class=\"text-white text-sm leading-relaxed\">\r\n          Just had the most amazing day at the beach! 🌊☀️ #BeachVibes #SummerFun\r\n       \r\n      <button\r\n      @click=\"showMore = !showMore\"\r\n      class=\"text-blue-400 mt-2 text-sm hover:underline\">\r\n      {{ showMore ? 'Show less' : 'Show more' }}\r\n          \r\n      </button>\r\n        </p>\r\n      </div>\r\n\r\n    \r\n      <!-- Video controls - bottom right -->\r\n     <div class=\"absolute inset-0 flex items-center justify-center bg-black/30   pointer-events-auto z-20\">\r\n        <button\r\n          @click=\"togglePlay\"\r\n          class=\"w-12 h-12 flex items-center justify-center rounded-full bg-black/60 backdrop-blur-lg text-white hover:bg-black/80 transition shadow-xl\" >\r\n          <Icon :icon=\"isPlaying ? 'solar:pause-bold' : 'solar:play-bold'\" class=\"w-7 h-7\" />\r\n        </button>\r\n\r\n        <!-- Mute button -->\r\n        <button\r\n          @click=\"toggleMute\"\r\n          class=\"w-12 h-12 flex items-center justify-center rounded-full bg-black/60 backdrop-blur-lg text-white hover:bg-black/80 transition shadow-xl\"\r\n        >\r\n          <Icon :icon=\"isMuted ? 'solar:volume-cross-bold' : 'solar:volume-loud-bold'\" class=\"w-7 h-7\" />\r\n        </button>\r\n      </div>\r\n      \r\n \r\n    </div>\r\n\r\n      <!-- Right vertical action buttons  Reels style -->\r\n      <div class=\" flex right-5 top-1/8 -translate-y-1/2 flex flex-col items-center gap-4 z-20 mt-80\">\r\n        <button class=\"group\">\r\n          <div class=\"w-13 h-13 flex items-center justify-center rounded-full bg-black/45 backdrop-blur-lg \r\n          shadow-xl group-hover:scale-110 transition-transform duration-200\">\r\n          <Icon icon=\"solar:heart-bold\" class=\"w-7 h-7 text-white group-hover:text-pink-400\" />\r\n          </div>\r\n        </button>\r\n\r\n        <button class=\"group\">\r\n          <div class=\"w-13 h-13 flex items-center justify-center rounded-full bg-black/45 backdrop-blur-lg \r\n          shadow-xl group-hover:scale-110 transition-transform duration-200\">\r\n            <Icon icon=\"solar:chat-line-bold\" class=\"w-7 h-7 text-white group-hover:text-blue-400\" />\r\n          </div>\r\n        </button>\r\n\r\n        <button class=\"group\">\r\n          <div class=\"w-13 h-13 flex items-center justify-center rounded-full bg-black/45 backdrop-blur-lg\r\n           shadow-xl group-hover:scale-110 transition-transform duration-200\">\r\n            <Icon icon=\"solar:share-bold\" class=\"w-7 h-7 text-white group-hover:text-green-400\" />\r\n          </div>\r\n        </button>\r\n\r\n        <button class=\"group\">\r\n          <div class=\"w-13 h-13 flex items-center justify-center rounded-full bg-black/45 backdrop-blur-lg shadow-xl \r\n          group-hover:scale-110 transition-transform duration-200\">\r\n            <Icon icon=\"solar:bookmark-bold\" class=\"w-7 h-7 text-white group-hover:text-yellow-400\" />\r\n          </div>\r\n        </button>\r\n      </div>\r\n\r\n\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onBeforeUnmount } from 'vue'\r\nimport { Icon } from '@iconify/vue'\r\nimport avatar from '@/assets/mini1.jpg'\r\n\r\n// Props\r\ndefineProps({\r\n  videoSrc: {\r\n    type: String,\r\n    required: true,\r\n  }\r\n})\r\n\r\n// Emits\r\ndefineEmits(['close'])\r\n\r\n// State\r\nconst isPlaying = ref(false)\r\nconst isMuted = ref(true)\r\nconst showMore = ref(false)\r\n\r\nconst videoRef = ref(null)\r\n\r\nconst fullText = `This is my little video project, inspired by Instagram Reels. I wanted to create a simple and elegant video player that mimics the feel of Reels, with smooth controls and a clean interface. It's built using Vue.js and Tailwind CSS, and I'm really happy with how it turned out!`\r\n\r\nconst shortText = computed(() => {\r\n  return fullText.substring(0, 120) + '...'\r\n})\r\n\r\n// Timer\r\nlet hideTimer = null\r\nconst controlsHidden = ref(false)\r\n\r\n// Methods\r\nconst togglePlay = () => {\r\n  const video = videoRef.value\r\n  if (!video) return\r\n\r\n  if (video.paused || video.ended) {\r\n    video.play()\r\n      .then(() => {\r\n        isPlaying.value = true\r\n        startHideTimer()\r\n      })\r\n      .catch(err => console.warn('Play blocked', err))\r\n  } else {\r\n    video.pause()\r\n    isPlaying.value = false\r\n    controlsHidden.value = false\r\n    clearHideTimer()\r\n  }\r\n}\r\n\r\nconst toggleMute = () => {\r\n  const video = videoRef.value\r\n  if (video) {\r\n    video.muted = !video.muted\r\n    isMuted.value = video.muted\r\n  }\r\n}\r\n\r\nconst onPlay = () => {\r\n  isPlaying.value = true\r\n  startHideTimer()\r\n}\r\n\r\nconst onPause = () => {\r\n  isPlaying.value = false\r\n  controlsHidden.value = false\r\n  clearHideTimer()\r\n}\r\n\r\nconst startHideTimer = () => {\r\n  clearHideTimer()\r\n\r\n  hideTimer = setTimeout(() => {\r\n    controlsHidden.value = true\r\n  }, 500)\r\n}\r\n\r\nconst clearHideTimer = () => {\r\n  if (hideTimer) {\r\n    clearTimeout(hideTimer)\r\n    hideTimer = null\r\n  }\r\n}\r\n\r\nconst resetHideTimer = () => {\r\n  if (isPlaying.value) {\r\n    controlsHidden.value = false\r\n    startHideTimer()\r\n  }\r\n}\r\n\r\nconst handleVideoClick = (e) => {\r\n  e.stopPropagation()\r\n  togglePlay()\r\n}\r\n\r\nconst goToMainfeed = () => {\r\n  console.log('→ Going to main feed')\r\n}\r\n\r\n// Cleanup\r\nonBeforeUnmount(() => {\r\n  if (videoRef.value) {\r\n    videoRef.value.pause?.()\r\n  }\r\n})\r\n</script>"],"mappings":"AA+IA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,eAAe,QAAQ,KAAK;AACpD,SAASC,IAAI,QAAQ,cAAc;AACnC,OAAOC,MAAM,MAAM,oBAAoB;;AAEvC;AAkBA,MAAMC,QAAQ,GAAG,sRAAsR;;;;;;;;;;;;;;;IAVvS;;IAGA;IACA,MAAMC,SAAS,GAAGN,GAAG,CAAC,KAAK,CAAC;IAC5B,MAAMO,OAAO,GAAGP,GAAG,CAAC,IAAI,CAAC;IACzB,MAAMQ,QAAQ,GAAGR,GAAG,CAAC,KAAK,CAAC;IAE3B,MAAMS,QAAQ,GAAGT,GAAG,CAAC,IAAI,CAAC;IAI1B,MAAMU,SAAS,GAAGT,QAAQ,CAAC,MAAM;MAC/B,OAAOI,QAAQ,CAACM,SAAS,CAAC,CAAC,EAAE,GAAG,CAAC,GAAG,KAAK;IAC3C,CAAC,CAAC;;IAEF;IACA,IAAIC,SAAS,GAAG,IAAI;IACpB,MAAMC,cAAc,GAAGb,GAAG,CAAC,KAAK,CAAC;;IAEjC;IACA,MAAMc,UAAU,GAAGA,CAAA,KAAM;MACvB,MAAMC,KAAK,GAAGN,QAAQ,CAACO,KAAK;MAC5B,IAAI,CAACD,KAAK,EAAE;MAEZ,IAAIA,KAAK,CAACE,MAAM,IAAIF,KAAK,CAACG,KAAK,EAAE;QAC/BH,KAAK,CAACI,IAAI,CAAC,CAAC,CACTC,IAAI,CAAC,MAAM;UACVd,SAAS,CAACU,KAAK,GAAG,IAAI;UACtBK,cAAc,CAAC,CAAC;QAClB,CAAC,CAAC,CACDC,KAAK,CAACC,GAAG,IAAIC,OAAO,CAACC,IAAI,CAAC,cAAc,EAAEF,GAAG,CAAC,CAAC;MACpD,CAAC,MAAM;QACLR,KAAK,CAACW,KAAK,CAAC,CAAC;QACbpB,SAAS,CAACU,KAAK,GAAG,KAAK;QACvBH,cAAc,CAACG,KAAK,GAAG,KAAK;QAC5BW,cAAc,CAAC,CAAC;MAClB;IACF,CAAC;IAED,MAAMC,UAAU,GAAGA,CAAA,KAAM;MACvB,MAAMb,KAAK,GAAGN,QAAQ,CAACO,KAAK;MAC5B,IAAID,KAAK,EAAE;QACTA,KAAK,CAACc,KAAK,GAAG,CAACd,KAAK,CAACc,KAAK;QAC1BtB,OAAO,CAACS,KAAK,GAAGD,KAAK,CAACc,KAAK;MAC7B;IACF,CAAC;IAED,MAAMC,MAAM,GAAGA,CAAA,KAAM;MACnBxB,SAAS,CAACU,KAAK,GAAG,IAAI;MACtBK,cAAc,CAAC,CAAC;IAClB,CAAC;IAED,MAAMU,OAAO,GAAGA,CAAA,KAAM;MACpBzB,SAAS,CAACU,KAAK,GAAG,KAAK;MACvBH,cAAc,CAACG,KAAK,GAAG,KAAK;MAC5BW,cAAc,CAAC,CAAC;IAClB,CAAC;IAED,MAAMN,cAAc,GAAGA,CAAA,KAAM;MAC3BM,cAAc,CAAC,CAAC;MAEhBf,SAAS,GAAGoB,UAAU,CAAC,MAAM;QAC3BnB,cAAc,CAACG,KAAK,GAAG,IAAI;MAC7B,CAAC,EAAE,GAAG,CAAC;IACT,CAAC;IAED,MAAMW,cAAc,GAAGA,CAAA,K