{"ast":null,"code":"import { ref, computed, onBeforeUnmount } from 'vue';\nimport { Icon } from '@iconify/vue';\nimport avatar from '@/assets/mini1.jpg';\n\n// Props\nconst fullText = `\nThis is my little video project, inspired by Instagram Reels.\nI wanted to create a simple and elegant video player that\nmimics the feel of Reels, with smooth controls and a clean\ninterface. It's built using Vue.js and Tailwind CSS,\nand I'm really happy with how it turned out!qwdqwdqwdqdqwdqdq2wdadqwqwdqdqwdwqd\n`;\nexport default {\n  __name: 'Reel',\n  props: {\n    videoSrc: {\n      type: String,\n      required: true\n    }\n  },\n  emits: ['close'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n\n    // Emits\n\n    // State\n    const isPlaying = ref(false);\n    const isMuted = ref(true);\n    const showMore = ref(false);\n    const videoRef = ref(null);\n    const shortText = computed(() => {\n      return fullText.substring(0, 120) + '...';\n    });\n\n    // Timer\n    let hideTimer = null;\n    const controlsHidden = ref(false);\n\n    // PLAY / PAUSE\n    const togglePlay = () => {\n      const video = videoRef.value;\n      if (!video) return;\n      if (video.paused || video.ended) {\n        video.play();\n        isPlaying.value = true;\n        startHideTimer();\n      } else {\n        video.pause();\n        isPlaying.value = false;\n        controlsHidden.value = false;\n        clearHideTimer();\n      }\n    };\n\n    // MUTE\n    const toggleMute = () => {\n      const video = videoRef.value;\n      if (video) {\n        video.muted = !video.muted;\n        isMuted.value = video.muted;\n      }\n    };\n\n    // PLAY EVENT\n    const onPlay = () => {\n      isPlaying.value = true;\n      startHideTimer();\n    };\n\n    // PAUSE EVENT\n    const onPause = () => {\n      isPlaying.value = false;\n      controlsHidden.value = false;\n      clearHideTimer();\n    };\n\n    // TIMER\n    const startHideTimer = () => {\n      clearHideTimer();\n      hideTimer = setTimeout(() => {\n        controlsHidden.value = true;\n      }, 500);\n    };\n    const clearHideTimer = () => {\n      if (hideTimer) {\n        clearTimeout(hideTimer);\n        hideTimer = null;\n      }\n    };\n    const resetHideTimer = () => {\n      if (isPlaying.value) {\n        controlsHidden.value = false;\n        startHideTimer();\n      }\n    };\n\n    // CLICK VIDEO\n    const handleVideoClick = e => {\n      e.stopPropagation();\n      togglePlay();\n    };\n\n    // NAVIGATION\n    const goToMainfeed = () => {\n      console.log('Go to main feed');\n    };\n\n    // CLEANUP\n    onBeforeUnmount(() => {\n      if (videoRef.value) {\n        videoRef.value.pause?.();\n      }\n    });\n    const __returned__ = {\n      isPlaying,\n      isMuted,\n      showMore,\n      videoRef,\n      fullText,\n      shortText,\n      get hideTimer() {\n        return hideTimer;\n      },\n      set hideTimer(v) {\n        hideTimer = v;\n      },\n      controlsHidden,\n      togglePlay,\n      toggleMute,\n      onPlay,\n      onPause,\n      startHideTimer,\n      clearHideTimer,\n      resetHideTimer,\n      handleVideoClick,\n      goToMainfeed,\n      ref,\n      computed,\n      onBeforeUnmount,\n      get Icon() {\n        return Icon;\n      },\n      get avatar() {\n        return avatar;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onBeforeUnmount","Icon","avatar","fullText","isPlaying","isMuted","showMore","videoRef","shortText","substring","hideTimer","controlsHidden","togglePlay","video","value","paused","ended","play","startHideTimer","pause","clearHideTimer","toggleMute","muted","onPlay","onPause","setTimeout","clearTimeout","resetHideTimer","handleVideoClick","e","stopPropagation","goToMainfeed","console","log"],"sources":["D:/login-feed/src/views/Reel.vue"],"sourcesContent":["<template>\r\n  <div\r\n    class=\"fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm\"\r\n    @click.self=\"$emit('close')\"\r\n  >\r\n    \r\n    <!-- Back button -->\r\n    <button\r\n      @click=\"goToMainfeed\"\r\n      class=\"absolute top-6 left-6 p-3 rounded-xl bg-green-600\r\n      hover:bg-green-700 border-4 border-green-500\r\n      hover:border-green-400 text-white transition-all duration-200 z-40 shadow-lg\"\r\n    >\r\n      <Icon icon=\"tdesign:chat-bubble\" class=\"w-9 h-9\" />\r\n    </button>\r\n\r\n    <!-- Reel Container -->\r\n    <div\r\n      class=\"relative w-[380px] h-[760px] rounded-[32px]\r\n      overflow-hidden bg-black shadow-2xl border border-white/10\"\r\n    >\r\n\r\n      <!-- VIDEO / IMAGE -->\r\n      <img\r\n        src=\"@/assets/girl.jpg\"\r\n        class=\"w-full h-full object-cover\"\r\n      />\r\n\r\n      <!-- DARK OVERLAY -->\r\n      <div\r\n        class=\"absolute inset-0\r\n        bg-gradient-to-b\r\n        from-black/20\r\n        via-transparent\r\n        to-black/80\"\r\n      ></div>\r\n\r\n      <!-- TOP BAR -->\r\n      <div\r\n        class=\"absolute top-5 left-5 right-5\r\n        flex items-center justify-between z-20\"\r\n      >\r\n\r\n        <button\r\n          class=\"w-10 h-10 rounded-full\r\n          bg-black/40 backdrop-blur-md\r\n          flex items-center justify-center\r\n          text-white hover:bg-black/60 transition\"\r\n        >\r\n          <Icon icon=\"mdi:close\" class=\"w-6 h-6\" />\r\n        </button>\r\n\r\n        <button\r\n          class=\"w-10 h-10 rounded-full\r\n          bg-green-500\r\n          flex items-center justify-center\r\n          text-white shadow-lg\"\r\n        >\r\n          <Icon icon=\"ic:outline-chat\" class=\"w-6 h-6\" />\r\n        </button>\r\n      </div>\r\n\r\n      <!-- RIGHT ACTIONS -->\r\n      <div\r\n        class=\"absolute right-4 bottom-32\r\n        flex flex-col items-center gap-5 z-20\"\r\n      >\r\n\r\n        <!-- Avatar -->\r\n        <div class=\"relative\">\r\n          <img\r\n            src=\"@/assets/avatar.jpg\"\r\n            class=\"w-14 h-14 rounded-full border-2 border-white object-cover\"\r\n          />\r\n\r\n          <button\r\n            class=\"absolute -bottom-1 left-1/2\r\n            -translate-x-1/2\r\n            w-6 h-6 rounded-full\r\n            bg-pink-500 text-white\r\n            flex items-center justify-center\r\n            text-sm border-2 border-black\"\r\n          >\r\n            +\r\n          </button>\r\n        </div>\r\n\r\n        <!-- Like -->\r\n        <button class=\"group\">\r\n          <div\r\n            class=\"w-14 h-14 rounded-full\r\n            bg-black/40 backdrop-blur-md\r\n            flex items-center justify-center\r\n            group-hover:scale-110 transition\"\r\n          >\r\n            <Icon\r\n              icon=\"solar:heart-bold\"\r\n              class=\"w-7 h-7 text-white group-hover:text-pink-400\"\r\n            />\r\n          </div>\r\n\r\n          <p class=\"text-white text-xs mt-1 text-center\">12.5K</p>\r\n        </button>\r\n\r\n        <!-- Comment -->\r\n        <button class=\"group\">\r\n          <div\r\n            class=\"w-14 h-14 rounded-full\r\n            bg-black/40 backdrop-blur-md\r\n            flex items-center justify-center\r\n            group-hover:scale-110 transition\"\r\n          >\r\n            <Icon\r\n              icon=\"solar:chat-round-bold\"\r\n              class=\"w-7 h-7 text-white group-hover:text-blue-400\"\r\n            />\r\n          </div>\r\n\r\n          <p class=\"text-white text-xs mt-1 text-center\">1.2K</p>\r\n        </button>\r\n\r\n        <!-- Share -->\r\n        <button class=\"group\">\r\n          <div\r\n            class=\"w-14 h-14 rounded-full\r\n            bg-black/40 backdrop-blur-md\r\n            flex items-center justify-center\r\n            group-hover:scale-110 transition\"\r\n          >\r\n            <Icon\r\n              icon=\"solar:share-bold\"\r\n              class=\"w-7 h-7 text-white group-hover:text-green-400\"\r\n            />\r\n          </div>\r\n\r\n          <p class=\"text-white text-xs mt-1 text-center\">Share</p>\r\n        </button>\r\n      </div>\r\n\r\n      <!-- BOTTOM CONTENT -->\r\n      <div\r\n        class=\"absolute bottom-0 left-0 right-0\r\n        p-5 z-20\"\r\n      >\r\n\r\n        <!-- User -->\r\n        <div class=\"flex items-center gap-3 mb-4\">\r\n\r\n          <img\r\n            src=\"@/assets/avatar.jpg\"\r\n            class=\"w-12 h-12 rounded-full object-cover border border-white/30\"\r\n          />\r\n\r\n          <div class=\"flex-1\">\r\n            <h3 class=\"text-white font-semibold text-lg\">\r\n              Jena\r\n            </h3>\r\n\r\n            <p class=\"text-white/70 text-sm\">\r\n              3h ago\r\n            </p>\r\n          </div>\r\n\r\n          <button\r\n            class=\"px-5 py-2 rounded-full\r\n            bg-white text-black font-medium\r\n            hover:scale-105 transition\"\r\n          >\r\n            Follow\r\n          </button>\r\n        </div>\r\n\r\n        <!-- Caption -->\r\n        <div class=\"text-white\">\r\n          <p class=\"leading-relaxed text-[15px]\">\r\n            {{\r\n              showMore\r\n                ? fullText\r\n                : shortText\r\n            }}\r\n          </p>\r\n\r\n          <button\r\n            @click=\"showMore = !showMore\"\r\n            class=\"text-blue-400 mt-2 text-sm hover:underline\"\r\n          >\r\n            {{ showMore ? 'Show less' : 'Show more' }}\r\n          </button>\r\n        </div>\r\n      </div>\r\n\r\n    </div>\r\n  \r\n\r\n\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onBeforeUnmount } from 'vue'\r\nimport { Icon } from '@iconify/vue'\r\nimport avatar from '@/assets/mini1.jpg'\r\n\r\n// Props\r\ndefineProps({\r\n  videoSrc: {\r\n    type: String,\r\n    required: true\r\n  }\r\n})\r\n\r\n// Emits\r\ndefineEmits(['close'])\r\n\r\n// State\r\nconst isPlaying = ref(false)\r\nconst isMuted = ref(true)\r\nconst showMore = ref(false)\r\n\r\nconst videoRef = ref(null)\r\n\r\nconst fullText = `\r\nThis is my little video project, inspired by Instagram Reels.\r\nI wanted to create a simple and elegant video player that\r\nmimics the feel of Reels, with smooth controls and a clean\r\ninterface. It's built using Vue.js and Tailwind CSS,\r\nand I'm really happy with how it turned out!qwdqwdqwdqdqwdqdq2wdadqwqwdqdqwdwqd\r\n`\r\n\r\nconst shortText = computed(() => {\r\n  return fullText.substring(0, 120) + '...'\r\n})\r\n\r\n// Timer\r\nlet hideTimer = null\r\nconst controlsHidden = ref(false)\r\n\r\n// PLAY / PAUSE\r\nconst togglePlay = () => {\r\n  const video = videoRef.value\r\n  if (!video) return\r\n\r\n  if (video.paused || video.ended) {\r\n    video.play()\r\n    isPlaying.value = true\r\n    startHideTimer()\r\n  } else {\r\n    video.pause()\r\n    isPlaying.value = false\r\n    controlsHidden.value = false\r\n    clearHideTimer()\r\n  }\r\n}\r\n\r\n// MUTE\r\nconst toggleMute = () => {\r\n  const video = videoRef.value\r\n\r\n  if (video) {\r\n    video.muted = !video.muted\r\n    isMuted.value = video.muted\r\n  }\r\n}\r\n\r\n// PLAY EVENT\r\nconst onPlay = () => {\r\n  isPlaying.value = true\r\n  startHideTimer()\r\n}\r\n\r\n// PAUSE EVENT\r\nconst onPause = () => {\r\n  isPlaying.value = false\r\n  controlsHidden.value = false\r\n  clearHideTimer()\r\n}\r\n\r\n// TIMER\r\nconst startHideTimer = () => {\r\n  clearHideTimer()\r\n\r\n  hideTimer = setTimeout(() => {\r\n    controlsHidden.value = true\r\n  }, 500)\r\n}\r\n\r\nconst clearHideTimer = () => {\r\n  if (hideTimer) {\r\n    clearTimeout(hideTimer)\r\n    hideTimer = null\r\n  }\r\n}\r\n\r\nconst resetHideTimer = () => {\r\n  if (isPlaying.value) {\r\n    controlsHidden.value = false\r\n    startHideTimer()\r\n  }\r\n}\r\n\r\n// CLICK VIDEO\r\nconst handleVideoClick = (e) => {\r\n  e.stopPropagation()\r\n  togglePlay()\r\n}\r\n\r\n// NAVIGATION\r\nconst goToMainfeed = () => {\r\n  console.log('Go to main feed')\r\n}\r\n\r\n// CLEANUP\r\nonBeforeUnmount(() => {\r\n  if (videoRef.value) {\r\n    videoRef.value.pause?.()\r\n  }\r\n})\r\n</script>"],"mappings":"AAuMA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,eAAe,QAAQ,KAAK;AACpD,SAASC,IAAI,QAAQ,cAAc;AACnC,OAAOC,MAAM,MAAM,oBAAoB;;AAEvC;AAkBA,MAAMC,QAAQ,GAAG;AACjB;AACA;AACA;AACA;AACA;AACA,CAAC;;;;;;;;;;;;;;;IAhBD;;IAGA;IACA,MAAMC,SAAS,GAAGN,GAAG,CAAC,KAAK,CAAC;IAC5B,MAAMO,OAAO,GAAGP,GAAG,CAAC,IAAI,CAAC;IACzB,MAAMQ,QAAQ,GAAGR,GAAG,CAAC,KAAK,CAAC;IAE3B,MAAMS,QAAQ,GAAGT,GAAG,CAAC,IAAI,CAAC;IAU1B,MAAMU,SAAS,GAAGT,QAAQ,CAAC,MAAM;MAC/B,OAAOI,QAAQ,CAACM,SAAS,CAAC,CAAC,EAAE,GAAG,CAAC,GAAG,KAAK;IAC3C,CAAC,CAAC;;IAEF;IACA,IAAIC,SAAS,GAAG,IAAI;IACpB,MAAMC,cAAc,GAAGb,GAAG,CAAC,KAAK,CAAC;;IAEjC;IACA,MAAMc,UAAU,GAAGA,CAAA,KAAM;MACvB,MAAMC,KAAK,GAAGN,QAAQ,CAACO,KAAK;MAC5B,IAAI,CAACD,KAAK,EAAE;MAEZ,IAAIA,KAAK,CAACE,MAAM,IAAIF,KAAK,CAACG,KAAK,EAAE;QAC/BH,KAAK,CAACI,IAAI,CAAC,CAAC;QACZb,SAAS,CAACU,KAAK,GAAG,IAAI;QACtBI,cAAc,CAAC,CAAC;MAClB,CAAC,MAAM;QACLL,KAAK,CAACM,KAAK,CAAC,CAAC;QACbf,SAAS,CAACU,KAAK,GAAG,KAAK;QACvBH,cAAc,CAACG,KAAK,GAAG,KAAK;QAC5BM,cAAc,CAAC,CAAC;MAClB;IACF,CAAC;;IAED;IACA,MAAMC,UAAU,GAAGA,CAAA,KAAM;MACvB,MAAMR,KAAK,GAAGN,QAAQ,CAACO,KAAK;MAE5B,IAAID,KAAK,EAAE;QACTA,KAAK,CAACS,KAAK,GAAG,CAACT,KAAK,CAACS,KAAK;QAC1BjB,OAAO,CAACS,KAAK,GAAGD,KAAK,CAACS,KAAK;MAC7B;IACF,CAAC;;IAED;IACA,MAAMC,MAAM,GAAGA,CAAA,KAAM;MACnBnB,SAAS,CAACU,KAAK,GAAG,IAAI;MACtBI,cAAc,CAAC,CAAC;IAClB,CAAC;;IAED;IACA,MAAMM,OAAO,GAAGA,CAAA,KAAM;MACpBpB,SAAS,CAACU,KAAK,GAAG,KAAK;MACvBH,cAAc,CAACG,KAAK,GAAG,KAAK;MAC5BM,cAAc,CAAC,CAAC;IAClB,CAAC;;IAED;IACA,MAAMF,cAAc,GAAGA,CAAA,KAAM;MAC3BE,cAAc,CAAC,CAAC;MAEhBV,SAAS,GAAGe,UAAU,CAAC,MAAM;QAC3Bd,cAAc,CAACG,KAAK,GAAG,IAAI;MAC7B,CAAC,EAAE,GAAG,CAAC;IACT,CAAC;IAED,MAAMM,cAAc,GAAGA,CAAA,KAAM;MAC3B,IAAIV,SAAS,EAAE;QACbgB,YAAY,CAAChB,SAAS,CAAC;QACvBA,SAAS,GAAG,IAAI