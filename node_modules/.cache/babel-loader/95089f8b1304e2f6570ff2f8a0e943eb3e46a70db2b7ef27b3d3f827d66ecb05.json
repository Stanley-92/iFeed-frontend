{"ast":null,"code":"import { ref, computed, onBeforeUnmount } from 'vue';\nimport { Icon } from '@iconify/vue';\nimport avatar from '@/assets/mini1.jpg';\n\n// Props\nconst fullText = `\nThis is my little video project, inspired by Instagram Reels.\nI wanted to create a simple and elegant video player that\nmimics the feel of Reels, with smooth controls and a clean\ninterface. It's built using Vue.js and Tailwind CSS,\nand I'm really happy with how it turned out!qwdqwdqwdqdqwdqdq2wdadqwqwdqdqwdwqd\n`;\nexport default {\n  __name: 'Reel',\n  props: {\n    videoSrc: {\n      type: String,\n      required: true\n    }\n  },\n  emits: ['close'],\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n\n    // Emits\n\n    // State\n    const isPlaying = ref(false);\n    const isMuted = ref(true);\n    const showMore = ref(false);\n    const videoRef = ref(null);\n    const shortText = computed(() => {\n      return fullText.substring(0, 120) + '...';\n    });\n\n    // Timer\n    let hideTimer = null;\n    const controlsHidden = ref(false);\n\n    // PLAY / PAUSE\n    const togglePlay = () => {\n      const video = videoRef.value;\n      if (!video) return;\n      if (video.paused || video.ended) {\n        video.play();\n        isPlaying.value = true;\n        startHideTimer();\n      } else {\n        video.pause();\n        isPlaying.value = false;\n        controlsHidden.value = false;\n        clearHideTimer();\n      }\n    };\n\n    // MUTE\n    const toggleMute = () => {\n      const video = videoRef.value;\n      if (video) {\n        video.muted = !video.muted;\n        isMuted.value = video.muted;\n      }\n    };\n\n    // PLAY EVENT\n    const onPlay = () => {\n      isPlaying.value = true;\n      startHideTimer();\n    };\n\n    // PAUSE EVENT\n    const onPause = () => {\n      isPlaying.value = false;\n      controlsHidden.value = false;\n      clearHideTimer();\n    };\n\n    // TIMER\n    const startHideTimer = () => {\n      clearHideTimer();\n      hideTimer = setTimeout(() => {\n        controlsHidden.value = true;\n      }, 500);\n    };\n    const clearHideTimer = () => {\n      if (hideTimer) {\n        clearTimeout(hideTimer);\n        hideTimer = null;\n      }\n    };\n    const resetHideTimer = () => {\n      if (isPlaying.value) {\n        controlsHidden.value = false;\n        startHideTimer();\n      }\n    };\n\n    // CLICK VIDEO\n    const handleVideoClick = e => {\n      e.stopPropagation();\n      togglePlay();\n    };\n\n    // NAVIGATION\n    const goToMainfeed = () => {\n      console.log('Go to main feed');\n    };\n\n    // CLEANUP\n    onBeforeUnmount(() => {\n      if (videoRef.value) {\n        videoRef.value.pause?.();\n      }\n    });\n    const __returned__ = {\n      isPlaying,\n      isMuted,\n      showMore,\n      videoRef,\n      fullText,\n      shortText,\n      get hideTimer() {\n        return hideTimer;\n      },\n      set hideTimer(v) {\n        hideTimer = v;\n      },\n      controlsHidden,\n      togglePlay,\n      toggleMute,\n      onPlay,\n      onPause,\n      startHideTimer,\n      clearHideTimer,\n      resetHideTimer,\n      handleVideoClick,\n      goToMainfeed,\n      ref,\n      computed,\n      onBeforeUnmount,\n      get Icon() {\n        return Icon;\n      },\n      get avatar() {\n        return avatar;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onBeforeUnmount","Icon","avatar","fullText","isPlaying","isMuted","showMore","videoRef","shortText","substring","hideTimer","controlsHidden","togglePlay","video","value","paused","ended","play","startHideTimer","pause","clearHideTimer","toggleMute","muted","onPlay","onPause","setTimeout","clearTimeout","resetHideTimer","handleVideoClick","e","stopPropagation","goToMainfeed","console","log"],"sources":["D:/login-feed/src/views/Reel.vue"],"sourcesContent":["<template>\r\n  <div\r\n    class=\"fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm\"\r\n    @click.self=\"$emit('close')\"\r\n  >\r\n    \r\n    <!-- Back button -->\r\n    <button\r\n      @click=\"goToMainfeed\"\r\n      class=\"absolute top-6 left-6 p-3 rounded-xl bg-green-600\r\n      hover:bg-green-700 border-4 border-green-500\r\n      hover:border-green-400 text-white transition-all duration-200 z-40 shadow-lg\"\r\n    >\r\n      <Icon icon=\"tdesign:chat-bubble\" class=\"w-9 h-9\" />\r\n    </button>\r\n\r\n    <!-- Reel Container -->\r\n    <div\r\n      class=\"relative w-full max-w-[420px] aspect-[9/16]\r\n      bg-gray-900 rounded-3xl overflow-hidden\r\n      shadow-2xl ring-1 ring-white/10\"\r\n      @click.stop\r\n    >\r\n\r\n      <!-- VIDEO -->\r\n      <div class=\"absolute inset-0\">\r\n        <video\r\n          ref=\"videoRef\"\r\n          class=\"h-full w-full object-cover\"\r\n          playsinline\r\n          loop\r\n          muted\r\n          :src=\"videoSrc\"\r\n          @click=\"handleVideoClick\"\r\n          @play=\"onPlay\"\r\n          @pause=\"onPause\"\r\n          @mousemove=\"resetHideTimer\"\r\n        ></video>\r\n\r\n        <!-- Overlay -->\r\n        <div\r\n          class=\"absolute inset-0 bg-gradient-to-b\r\n          from-black/20 via-transparent to-black/70\r\n          pointer-events-none\"\r\n        />\r\n      </div>\r\n\r\n      <!-- TOP BAR -->\r\n      <div\r\n        class=\"absolute top-4 left-4 right-4\r\n        flex items-center justify-between z-30\"\r\n      >\r\n        <div class=\"flex-1 h-1 bg-white/40 rounded-full overflow-hidden\">\r\n          <div\r\n            class=\"h-full w-3/5 bg-white rounded-full\r\n            transition-all duration-[4500ms]\"\r\n          />\r\n        </div>\r\n\r\n        <button\r\n          @click=\"$emit('close')\"\r\n          class=\"ml-3 p-2 rounded-full\r\n          hover:bg-white/20 text-white transition-colors\"\r\n        >\r\n          <Icon icon=\"mdi:close\" class=\"w-7 h-7\" />\r\n        </button>\r\n      </div>\r\n\r\n      <!-- BOTTOM INFO -->\r\n      <div class=\"absolute bottom-0 left-0 right-0 p-5 pb-10\">\r\n\r\n        <!-- User -->\r\n        <div class=\"flex items-center justify-between mb-4\">\r\n\r\n          <div class=\"flex items-center gap-3\">\r\n            <div\r\n              class=\"w-10 h-10 rounded-full ring-2\r\n              ring-white/50 overflow-hidden shadow-sm\"\r\n            >\r\n              <img\r\n                :src=\"avatar\"\r\n                alt=\"Jena\"\r\n                class=\"w-full h-full object-cover\"\r\n              />\r\n            </div>\r\n\r\n            <div class=\"text-white\">\r\n              <p class=\"font-semibold\">Jena</p>\r\n              <p class=\"text-xs text-white/80\">3h ago</p>\r\n            </div>\r\n          </div>\r\n\r\n          <button\r\n            class=\"px-5 py-1.5 bg-white/95 text-black\r\n            text-sm font-medium rounded-full hover:bg-white transition\"\r\n          >\r\n            Follow\r\n          </button>\r\n        </div>\r\n\r\n        <!-- Caption -->\r\n        <div class=\"text-white text-sm leading-relaxed\">\r\n\r\n          <p>\r\n            {{ showMore ? fullText : shortText }}\r\n          </p>\r\n\r\n          <button\r\n            @click=\"showMore = !showMore\"\r\n            class=\"text-blue-400 mt-1 text-sm hover:underline\"\r\n          >\r\n            {{ showMore ? 'Show less' : 'Show more' }}\r\n          </button>\r\n\r\n        </div>\r\n      </div>\r\n\r\n      <!-- CENTER CONTROLS -->\r\n      <div\r\n        class=\"absolute inset-0 flex items-center\r\n        justify-center gap-4 z-20\"\r\n      >\r\n\r\n        <!-- Play -->\r\n        <button\r\n          @click=\"togglePlay\"\r\n          class=\"w-12 h-12 flex items-center justify-center\r\n          rounded-full bg-black/60 backdrop-blur-lg\r\n          text-white hover:bg-black/80 transition shadow-xl\"\r\n        >\r\n          <Icon\r\n            :icon=\"isPlaying\r\n              ? 'solar:pause-bold'\r\n              : 'solar:play-bold'\"\r\n            class=\"w-7 h-7\"\r\n          />\r\n        </button>\r\n\r\n        <!-- Mute -->\r\n        <button\r\n          @click=\"toggleMute\"\r\n          class=\"w-12 h-12 flex items-center justify-center\r\n          rounded-full bg-black/60 backdrop-blur-lg\r\n          text-white hover:bg-black/80 transition shadow-xl\"\r\n        >\r\n          <Icon\r\n            :icon=\"isMuted\r\n              ? 'solar:volume-cross-bold'\r\n              : 'solar:volume-loud-bold'\"\r\n            class=\"w-7 h-7\"\r\n          />\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- RIGHT ACTION BUTTONS -->\r\n    <div\r\n      class=\"flex right-5 top-1/8 -translate-y-1/2\r\n      flex-col items-center gap-4 z-20 mt-80\"\r\n    >\r\n\r\n      <button class=\"group\">\r\n        <div\r\n          class=\"w-13 h-13 flex items-center justify-center\r\n          rounded-full bg-black/45 backdrop-blur-lg\r\n          shadow-xl group-hover:scale-110\r\n          transition-transform duration-200\"\r\n        >\r\n          <Icon\r\n            icon=\"solar:heart-bold\"\r\n            class=\"w-7 h-7 text-white group-hover:text-pink-400\"\r\n          />\r\n        </div>\r\n      </button>\r\n\r\n      <button class=\"group\">\r\n        <div\r\n          class=\"w-13 h-13 flex items-center justify-center\r\n          rounded-full bg-black/45 backdrop-blur-lg\r\n          shadow-xl group-hover:scale-110\r\n          transition-transform duration-200\"\r\n        >\r\n          <Icon\r\n            icon=\"solar:chat-line-bold\"\r\n            class=\"w-7 h-7 text-white group-hover:text-blue-400\"\r\n          />\r\n        </div>\r\n      </button>\r\n\r\n      <button class=\"group\">\r\n        <div\r\n          class=\"w-13 h-13 flex items-center justify-center\r\n          rounded-full bg-black/45 backdrop-blur-lg\r\n          shadow-xl group-hover:scale-110\r\n          transition-transform duration-200\"\r\n        >\r\n          <Icon\r\n            icon=\"solar:share-bold\"\r\n            class=\"w-7 h-7 text-white group-hover:text-green-400\"\r\n          />\r\n        </div>\r\n      </button>\r\n\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onBeforeUnmount } from 'vue'\r\nimport { Icon } from '@iconify/vue'\r\nimport avatar from '@/assets/mini1.jpg'\r\n\r\n// Props\r\ndefineProps({\r\n  videoSrc: {\r\n    type: String,\r\n    required: true\r\n  }\r\n})\r\n\r\n// Emits\r\ndefineEmits(['close'])\r\n\r\n// State\r\nconst isPlaying = ref(false)\r\nconst isMuted = ref(true)\r\nconst showMore = ref(false)\r\n\r\nconst videoRef = ref(null)\r\n\r\nconst fullText = `\r\nThis is my little video project, inspired by Instagram Reels.\r\nI wanted to create a simple and elegant video player that\r\nmimics the feel of Reels, with smooth controls and a clean\r\ninterface. It's built using Vue.js and Tailwind CSS,\r\nand I'm really happy with how it turned out!qwdqwdqwdqdqwdqdq2wdadqwqwdqdqwdwqd\r\n`\r\n\r\nconst shortText = computed(() => {\r\n  return fullText.substring(0, 120) + '...'\r\n})\r\n\r\n// Timer\r\nlet hideTimer = null\r\nconst controlsHidden = ref(false)\r\n\r\n// PLAY / PAUSE\r\nconst togglePlay = () => {\r\n  const video = videoRef.value\r\n  if (!video) return\r\n\r\n  if (video.paused || video.ended) {\r\n    video.play()\r\n    isPlaying.value = true\r\n    startHideTimer()\r\n  } else {\r\n    video.pause()\r\n    isPlaying.value = false\r\n    controlsHidden.value = false\r\n    clearHideTimer()\r\n  }\r\n}\r\n\r\n// MUTE\r\nconst toggleMute = () => {\r\n  const video = videoRef.value\r\n\r\n  if (video) {\r\n    video.muted = !video.muted\r\n    isMuted.value = video.muted\r\n  }\r\n}\r\n\r\n// PLAY EVENT\r\nconst onPlay = () => {\r\n  isPlaying.value = true\r\n  startHideTimer()\r\n}\r\n\r\n// PAUSE EVENT\r\nconst onPause = () => {\r\n  isPlaying.value = false\r\n  controlsHidden.value = false\r\n  clearHideTimer()\r\n}\r\n\r\n// TIMER\r\nconst startHideTimer = () => {\r\n  clearHideTimer()\r\n\r\n  hideTimer = setTimeout(() => {\r\n    controlsHidden.value = true\r\n  }, 500)\r\n}\r\n\r\nconst clearHideTimer = () => {\r\n  if (hideTimer) {\r\n    clearTimeout(hideTimer)\r\n    hideTimer = null\r\n  }\r\n}\r\n\r\nconst resetHideTimer = () => {\r\n  if (isPlaying.value) {\r\n    controlsHidden.value = false\r\n    startHideTimer()\r\n  }\r\n}\r\n\r\n// CLICK VIDEO\r\nconst handleVideoClick = (e) => {\r\n  e.stopPropagation()\r\n  togglePlay()\r\n}\r\n\r\n// NAVIGATION\r\nconst goToMainfeed = () => {\r\n  console.log('Go to main feed')\r\n}\r\n\r\n// CLEANUP\r\nonBeforeUnmount(() => {\r\n  if (videoRef.value) {\r\n    videoRef.value.pause?.()\r\n  }\r\n})\r\n</script>"],"mappings":"AAgNA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,eAAe,QAAQ,KAAK;AACpD,SAASC,IAAI,QAAQ,cAAc;AACnC,OAAOC,MAAM,MAAM,oBAAoB;;AAEvC;AAkBA,MAAMC,QAAQ,GAAG;AACjB;AACA;AACA;AACA;AACA;AACA,CAAC;;;;;;;;;;;;;;;IAhBD;;IAGA;IACA,MAAMC,SAAS,GAAGN,GAAG,CAAC,KAAK,CAAC;IAC5B,MAAMO,OAAO,GAAGP,GAAG,CAAC,IAAI,CAAC;IACzB,MAAMQ,QAAQ,GAAGR,GAAG,CAAC,KAAK,CAAC;IAE3B,MAAMS,QAAQ,GAAGT,GAAG,CAAC,IAAI,CAAC;IAU1B,MAAMU,SAAS,GAAGT,QAAQ,CAAC,MAAM;MAC/B,OAAOI,QAAQ,CAACM,SAAS,CAAC,CAAC,EAAE,GAAG,CAAC,GAAG,KAAK;IAC3C,CAAC,CAAC;;IAEF;IACA,IAAIC,SAAS,GAAG,IAAI;IACpB,MAAMC,cAAc,GAAGb,GAAG,CAAC,KAAK,CAAC;;IAEjC;IACA,MAAMc,UAAU,GAAGA,CAAA,KAAM;MACvB,MAAMC,KAAK,GAAGN,QAAQ,CAACO,KAAK;MAC5B,IAAI,CAACD,KAAK,EAAE;MAEZ,IAAIA,KAAK,CAACE,MAAM,IAAIF,KAAK,CAACG,KAAK,EAAE;QAC/BH,KAAK,CAACI,IAAI,CAAC,CAAC;QACZb,SAAS,CAACU,KAAK,GAAG,IAAI;QACtBI,cAAc,CAAC,CAAC;MAClB,CAAC,MAAM;QACLL,KAAK,CAACM,KAAK,CAAC,CAAC;QACbf,SAAS,CAACU,KAAK,GAAG,KAAK;QACvBH,cAAc,CAACG,KAAK,GAAG,KAAK;QAC5BM,cAAc,CAAC,CAAC;MAClB;IACF,CAAC;;IAED;IACA,MAAMC,UAAU,GAAGA,CAAA,KAAM;MACvB,MAAMR,KAAK,GAAGN,QAAQ,CAACO,KAAK;MAE5B,IAAID,KAAK,EAAE;QACTA,KAAK,CAACS,KAA